# ============================================================
# Grandcom Gold Signals — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# MongoDB
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/
DB_NAME=gold_signals

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_GOLD_CHANNEL_ID=@grandcomgold

# TwelveData API (price data)
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# OpenAI / LLM (for AI signal analysis)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Black box logging paths
BLACKBOX_LOG=blackbox_trades.jsonl
DENIAL_LOG=denial_log.csv
TRAILING_LOG=trailing_stops.jsonl
