# Grandcom Gold Signals — Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# MongoDB
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/
DB_NAME=gold_signals

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_GOLD_CHANNEL_ID=@grandcomgold

# TwelveData (price data & news)
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# OpenAI (signal analysis)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Stripe (subscriptions)
STRIPE_API_KEY=sk_live_your_stripe_key_here

# Server port (Railway sets this automatically)
PORT=8002
