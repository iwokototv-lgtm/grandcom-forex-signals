# ============================================================
# Grandcom Gold Signals v3.0 — Environment Variables Template
# Copy to .env and fill in your values before deploying.
# ============================================================

# ── Core Infrastructure ──────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=gold_signals_v3
REDIS_URL=redis://localhost:6379

# ── API Keys ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TWELVE_DATA_API_KEY=your_twelvedata_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Telegram Channels ────────────────────────────────────────
# Use numeric ID (e.g. -1001234567890) or @username
TELEGRAM_GOLD_CHANNEL_ID=-1001234567890

# ── Signal Generation ────────────────────────────────────────
SIGNAL_INTERVAL_MINUTES=30
MIN_CONFIDENCE=65
MAX_SIGNALS_PER_DAY=8
MIN_SIGNAL_GAP_MINUTES=30

# ── Multi-Timeframe ──────────────────────────────────────────
MTF_MIN_CONFLUENCE=3

# ── Risk Management ──────────────────────────────────────────
BASE_RISK_PER_TRADE=0.01
MAX_RISK_PER_TRADE=0.02
MIN_RISK_PER_TRADE=0.005
DAILY_LOSS_LIMIT=0.03
WEEKLY_LOSS_LIMIT=0.06
MONTHLY_DRAWDOWN_CAP=0.12
MAX_CONSECUTIVE_LOSSES=3
ACCOUNT_BALANCE=100000

# ── Correlation Engine ───────────────────────────────────────
CORRELATION_WINDOW=30
CORRELATION_CAP=0.70
BETA_LOOKBACK=60
USD_CLUSTER_THRESHOLD=0.65

# ── Risk Parity ──────────────────────────────────────────────
RISK_PARITY_LOOKBACK=20
RISK_PARITY_TARGET_VOL=0.10

# ── Volatility Adjustment ────────────────────────────────────
VOL_LOOKBACK=20

# ── Drawdown Recovery ────────────────────────────────────────
DRAWDOWN_RECOVERY_THRESHOLD=0.05
DRAWDOWN_RECOVERY_SCALE=0.50

# ── Economic Calendar ────────────────────────────────────────
ECONOMIC_CALENDAR_ENABLED=true
HIGH_IMPACT_BLACKOUT_MINUTES=60
MEDIUM_IMPACT_BLACKOUT_MINUTES=30

# ── Performance Tracking ─────────────────────────────────────
PERFORMANCE_LOOKBACK_DAYS=30
ATTRIBUTION_ENABLED=true

# ── System ───────────────────────────────────────────────────
LOG_LEVEL=INFO
PORT=8000
