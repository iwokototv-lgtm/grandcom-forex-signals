# ============================================================
# Grandcom Gold Signals v3.0 — Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================

# ── Core Infrastructure ──────────────────────────────────────
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/
DB_NAME=gold_signals_v3
PORT=8002
HOST=0.0.0.0
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=false

# ── API Keys ─────────────────────────────────────────────────
TWELVE_DATA_API_KEY=your_twelve_data_api_key
OPENAI_API_KEY=your_openai_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
FRED_API_KEY=your_fred_api_key

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_GOLD_CHANNEL_ID=-1003834233408

# ── Signal Generation ────────────────────────────────────────
SIGNAL_INTERVAL_MINUTES=2
MIN_CONFIDENCE=60
MIN_SMC_SCORE=4
MIN_MTF_CONFLUENCE=2

# ── Risk Management ──────────────────────────────────────────
MAX_ACCOUNT_RISK_PCT=2.0
MAX_DAILY_DRAWDOWN_PCT=5.0
MAX_TOTAL_DRAWDOWN_PCT=15.0
DEFAULT_ACCOUNT_BALANCE=10000.0
RISK_PARITY_LOOKBACK=60
VOLATILITY_LOOKBACK=20
DRAWDOWN_RECOVERY_FACTOR=0.5

# ── Regime Detection ─────────────────────────────────────────
REGIME_HYSTERESIS=3
ADX_TREND_THRESHOLD=25.0
ATR_HIGH_VOL_RATIO=1.5
ATR_LOW_VOL_RATIO=0.6

# ── Multi-Timeframe ──────────────────────────────────────────
MTF_MIN_ALIGNMENT=60.0

# ── Correlation Engine ───────────────────────────────────────
BETA_LOOKBACK=60
USD_CLUSTER_THRESHOLD=0.7

# ── Economic Calendar ────────────────────────────────────────
ECONOMIC_CALENDAR_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json
HIGH_IMPACT_BLACKOUT_MINUTES=30

# ── Performance & Journaling ─────────────────────────────────
PERFORMANCE_LOOKBACK_DAYS=30
JOURNAL_MAX_ENTRIES=1000
