# ============================================================
# Grandcom Gold Signals — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# MongoDB connection string (Railway MongoDB plugin or Atlas)
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/

# MongoDB database name (default: gold_signals)
DB_NAME=gold_signals

# Telegram bot token for @grandcomgold channel
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram channel ID where gold signals are posted
# Use @channelname or numeric ID (e.g. -1001234567890)
TELEGRAM_GOLD_CHANNEL_ID=@grandcomgold

# Twelve Data API key for price data
# Get from https://twelvedata.com
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# OpenAI API key for AI signal analysis (gpt-4o-mini)
# Get from https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Emergent LLM key (alternative to OpenAI)
# EMERGENT_LLM_KEY=your_emergent_key_here

# Optional: Black box log file paths (defaults shown)
# BLACKBOX_LOG=blackbox_trades.jsonl
# DENIAL_LOG=denial_log.csv
# TRAILING_LOG=trailing_stops.jsonl

# Railway sets PORT automatically — do not set manually
# PORT=8002
