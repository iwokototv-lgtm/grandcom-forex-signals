# ============================================================
# Grandcom Gold Signals — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── MongoDB ──────────────────────────────────────────────────
# Full MongoDB connection string (Atlas or Railway MongoDB plugin)
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name (default: gold_signals)
DB_NAME=gold_signals

# ── Telegram ─────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=<your_telegram_bot_token>

# Channel where Gold signals are posted (e.g. @grandcomgold or numeric ID)
TELEGRAM_GOLD_CHANNEL_ID=@grandcomgold

# ── Price Data ───────────────────────────────────────────────
# TwelveData API key — used for OHLCV price feeds and economic calendar
# Get yours at: https://twelvedata.com/
TWELVE_DATA_API_KEY=<your_twelvedata_api_key>

# ── AI Analysis ──────────────────────────────────────────────
# OpenAI API key — used for GPT-4o-mini signal analysis
# Also accepted as EMERGENT_LLM_KEY (fallback)
OPENAI_API_KEY=<your_openai_api_key>

# ── Optional: Log file paths (defaults shown) ────────────────
# BLACKBOX_LOG=blackbox_trades.jsonl
# DENIAL_LOG=denial_log.csv
# TRAILING_LOG=trailing_stops.jsonl
